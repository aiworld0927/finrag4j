# FinRag4j 环境变量配置文件
# 使用方式：在application.yml中通过 ${POSTGRES_HOST} 引用

# 数据库配置
POSTGRES_HOST=192.168.222.186
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Vector@123

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# MinIO配置
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=finrag4j

# RocketMQ配置
ROCKETMQ_NAME_SERVER=localhost:9876

# Python服务配置
PYTHON_SERVICE_BASE_URL=http://localhost:8001

# 大模型配置
LLM_TYPE=ollama
LLM_BASE_URL=http://localhost:11434
LLM_DEFAULT_MODEL=qwen2:7b

# 运行环境
SPRING_PROFILES_ACTIVE=dev