# FinRag4j 开发环境配置
# 运行命令: docker-compose --env-file .env.dev up -d

# ---------------------------
# 网络配置
# ---------------------------
NETWORK_NAME=finrag4j-network-dev

# ---------------------------
# PostgreSQL 配置
# ---------------------------
POSTGRES_CONTAINER_NAME=finrag4j-postgres-dev
POSTGRES_PORT=5433
POSTGRES_DB=finrag4j_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev@123

# ---------------------------
# Redis Stack Server 配置
# ---------------------------
REDIS_CONTAINER_NAME=finrag4j-redis-dev
REDIS_PORT=6380
REDIS_PASSWORD=

# ---------------------------
# MinIO 配置
# ---------------------------
MINIO_CONTAINER_NAME=finrag4j-minio-dev
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---------------------------
# RocketMQ 配置
# ---------------------------
ROCKETMQ_NAMESRV_CONTAINER_NAME=finrag4j-rocketmq-namesrv-dev
ROCKETMQ_NAMESRV_PORT=9877
ROCKETMQ_BROKER_CONTAINER_NAME=finrag4j-rocketmq-broker-dev
ROCKETMQ_BROKER_PORT=10912
ROCKETMQ_BROKER_PORT2=10910
ROCKETMQ_DASHBOARD_CONTAINER_NAME=finrag4j-rocketmq-dashboard-dev
ROCKETMQ_DASHBOARD_PORT=8089

# ---------------------------
# Python 服务配置
# ---------------------------
PYTHON_CONTAINER_NAME=finrag4j-python-dev
PYTHON_SERVICE_PORT=8002

# ---------------------------
# Java 服务配置
# ---------------------------
JAVA_CONTAINER_NAME=finrag4j-java-dev
JAVA_SERVICE_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# ---------------------------
# Ollama 配置（使用外部固定地址）
# ---------------------------
OLLAMA_CONTAINER_NAME=finrag4j-ollama-dev
OLLAMA_PORT=11435
OLLAMA_BASE_URL=http://192.168.222.1:11434

# ---------------------------
# 前端配置
# ---------------------------
FRONTEND_CONTAINER_NAME=finrag4j-frontend-dev
FRONTEND_PORT=81
VUE_APP_API_BASE_URL=http://localhost:8081/api

# ---------------------------
# 部署模式
# ---------------------------
DEPLOY_MODE=development
LOG_LEVEL=DEBUG