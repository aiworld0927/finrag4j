# FinRag4j 测试环境配置
# 运行命令: docker-compose --env-file .env.test up -d

# ---------------------------
# 网络配置
# ---------------------------
NETWORK_NAME=finrag4j-network-test

# ---------------------------
# PostgreSQL 配置
# ---------------------------
POSTGRES_CONTAINER_NAME=finrag4j-postgres-test
POSTGRES_PORT=5434
POSTGRES_DB=finrag4j_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=test@123

# ---------------------------
# Redis Stack Server 配置
# ---------------------------
REDIS_CONTAINER_NAME=finrag4j-redis-test
REDIS_PORT=6381
REDIS_PASSWORD=testredis@123

# ---------------------------
# MinIO 配置
# ---------------------------
MINIO_CONTAINER_NAME=finrag4j-minio-test
MINIO_PORT=9004
MINIO_CONSOLE_PORT=9005
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=miniotest@123

# ---------------------------
# RocketMQ 配置
# ---------------------------
ROCKETMQ_NAMESRV_CONTAINER_NAME=finrag4j-rocketmq-namesrv-test
ROCKETMQ_NAMESRV_PORT=9878
ROCKETMQ_BROKER_CONTAINER_NAME=finrag4j-rocketmq-broker-test
ROCKETMQ_BROKER_PORT=10913
ROCKETMQ_BROKER_PORT2=10911
ROCKETMQ_DASHBOARD_CONTAINER_NAME=finrag4j-rocketmq-dashboard-test
ROCKETMQ_DASHBOARD_PORT=8090

# ---------------------------
# Python 服务配置
# ---------------------------
PYTHON_CONTAINER_NAME=finrag4j-python-test
PYTHON_SERVICE_PORT=8003

# ---------------------------
# Java 服务配置
# ---------------------------
JAVA_CONTAINER_NAME=finrag4j-java-test
JAVA_SERVICE_PORT=8082
SPRING_PROFILES_ACTIVE=test

# ---------------------------
# Ollama 配置（使用外部固定地址）
# ---------------------------
OLLAMA_CONTAINER_NAME=finrag4j-ollama-test
OLLAMA_PORT=11436
OLLAMA_BASE_URL=http://192.168.222.1:11434

# ---------------------------
# 前端配置
# ---------------------------
FRONTEND_CONTAINER_NAME=finrag4j-frontend-test
FRONTEND_PORT=82
VUE_APP_API_BASE_URL=http://localhost:8082/api

# ---------------------------
# 部署模式
# ---------------------------
DEPLOY_MODE=testing
LOG_LEVEL=INFO