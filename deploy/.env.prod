# FinRag4j 生产环境配置
# 运行命令: docker-compose --env-file .env.prod up -d

# ---------------------------
# 网络配置
# ---------------------------
NETWORK_NAME=finrag4j-network-prod

# ---------------------------
# PostgreSQL 配置
# ---------------------------
POSTGRES_CONTAINER_NAME=finrag4j-postgres-prod
POSTGRES_PORT=5432
POSTGRES_DB=finrag4j_prod
POSTGRES_USER=prod_user
POSTGRES_PASSWORD=Prod@Postgres2024

# ---------------------------
# Redis Stack Server 配置
# ---------------------------
REDIS_CONTAINER_NAME=finrag4j-redis-prod
REDIS_PORT=6379
REDIS_PASSWORD=Prod@Redis2024

# ---------------------------
# MinIO 配置
# ---------------------------
MINIO_CONTAINER_NAME=finrag4j-minio-prod
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=prod_minio_admin
MINIO_ROOT_PASSWORD=Prod@MinIO2024

# ---------------------------
# RocketMQ 配置
# ---------------------------
ROCKETMQ_NAMESRV_CONTAINER_NAME=finrag4j-rocketmq-namesrv-prod
ROCKETMQ_NAMESRV_PORT=9876
ROCKETMQ_BROKER_CONTAINER_NAME=finrag4j-rocketmq-broker-prod
ROCKETMQ_BROKER_PORT=10911
ROCKETMQ_BROKER_PORT2=10909
ROCKETMQ_DASHBOARD_CONTAINER_NAME=finrag4j-rocketmq-dashboard-prod
ROCKETMQ_DASHBOARD_PORT=8088

# ---------------------------
# Python 服务配置
# ---------------------------
PYTHON_CONTAINER_NAME=finrag4j-python-prod
PYTHON_SERVICE_PORT=8001

# ---------------------------
# Java 服务配置
# ---------------------------
JAVA_CONTAINER_NAME=finrag4j-java-prod
JAVA_SERVICE_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# ---------------------------
# Ollama 配置（使用外部固定地址）
# ---------------------------
OLLAMA_CONTAINER_NAME=finrag4j-ollama-prod
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://192.168.222.1:11434

# ---------------------------
# 前端配置
# ---------------------------
FRONTEND_CONTAINER_NAME=finrag4j-frontend-prod
FRONTEND_PORT=80
VUE_APP_API_BASE_URL=http://localhost:8080/api

# ---------------------------
# 部署模式
# ---------------------------
DEPLOY_MODE=production
LOG_LEVEL=WARN